local autoRunning = true

local Players = game:GetService("Players")
local GuiService = game:GetService("GuiService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local tradeEvents = ReplicatedStorage:WaitForChild("GameEvents"):WaitForChild("TradeEvents")
local acceptEvent = tradeEvents:WaitForChild("Accept")
local confirmEvent = tradeEvents:WaitForChild("Confirm")

-- AUTO ACCEPT GIFT
task.spawn(function()
    local giftNotif = playerGui:WaitForChild("Gift_Notification")

    local function isAcceptButton(btn)
        if not (btn:IsA("TextButton") or btn:IsA("ImageButton")) then
            return false
        end

        if not btn.Visible then
            return false
        end

        local text = btn:IsA("TextButton") and string.lower(btn.Text) or ""
        local name = string.lower(btn.Name)

        return string.find(text, "accept")
            or string.find(name, "accept")
    end

    local function clickAccept(btn)
        task.spawn(function()
            task.wait(0.1)

            GuiService.SelectedObject = btn

            VirtualInputManager:SendKeyEvent(
                true,
                Enum.KeyCode.Return,
                false,
                game
            )

            VirtualInputManager:SendKeyEvent(
                false,
                Enum.KeyCode.Return,
                false,
                game
            )

            GuiService.SelectedObject = nil
        end)
    end

    local function handle(obj)
        if isAcceptButton(obj) then
            clickAccept(obj)
        end
    end

    for _, v in ipairs(giftNotif:GetDescendants()) do
        handle(v)
    end

    giftNotif.DescendantAdded:Connect(handle)
end)

-- AUTO ACCEPT + CONFIRM TRADE
task.spawn(function()
    while autoRunning do
        acceptEvent:FireServer()
        task.wait(2)

        confirmEvent:FireServer()
        task.wait(2)
    end
end)
