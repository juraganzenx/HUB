-- ACCEPT TOKEN
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local GuiService = game:GetService("GuiService")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local tradeEvents = ReplicatedStorage:WaitForChild("GameEvents"):WaitForChild("TradeEvents")
local acceptEvent = tradeEvents:WaitForChild("Accept")
local confirmEvent = tradeEvents:WaitForChild("Confirm")

-- AUTO ACCEPT GIFT
task.spawn(function()
    local giftNotif = playerGui:WaitForChild("Gift_Notification")

    local function isAcceptButton(obj)
        if not (obj:IsA("TextButton") or obj:IsA("ImageButton")) then
            return false
        end

        if not obj.Visible then
            return false
        end

        local text = obj:IsA("TextButton") and string.lower(obj.Text) or ""
        local name = string.lower(obj.Name)

        return string.find(text, "accept")
            or string.find(name, "accept")
    end

    local function clickButton(btn)
        task.spawn(function()
            GuiService.SelectedObject = btn

            -- tunggu 1 detik sebelum tekan Enter
            task.wait(1)

            VirtualInputManager:SendKeyEvent(
                true,
                Enum.KeyCode.Return,
                false,
                game
            )

            VirtualInputManager:SendKeyEvent(
                false,
                Enum.KeyCode.Return,
                false,
                game
            )

            task.wait(0.05)
            GuiService.SelectedObject = nil
        end)
    end

    local function handle(obj)
        if isAcceptButton(obj) then
            clickButton(obj)
        end
    end

    for _, v in ipairs(giftNotif:GetDescendants()) do
        handle(v)
    end

    giftNotif.DescendantAdded:Connect(handle)
end)

-- AUTO ACCEPT + CONFIRM TRADE
task.spawn(function()
    while true do
        pcall(function()
            acceptEvent:FireServer()
        end)

        task.wait(2)

        pcall(function()
            confirmEvent:FireServer()
        end)

        task.wait(2)
    end
end)
